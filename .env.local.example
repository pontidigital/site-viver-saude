# Anthropic (Claude API for admin AI chat)
ANTHROPIC_API_KEY=your-anthropic-api-key

# RD Station (optional - can also be set via admin panel)
NEXT_PUBLIC_RD_STATION_TOKEN=your-rd-token

# Site URL
NEXT_PUBLIC_SITE_URL=https://planoviversaude.com.br
